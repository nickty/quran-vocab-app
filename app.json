{
  "expo": {
    "name": "Quran Vocabulary",
    "slug": "quran-vocabulary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.quranvocab"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.yourcompany.quranvocab",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for speech recognition."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#2E7D32",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#2E7D32",
      "barStyle": "light-content"
    },
    "description": "Learn Quranic vocabulary with pronunciation, quizzes, and progress tracking",
    "githubUrl": "https://github.com/nickty/quran-vocab-app"
  },
   "cli": {
      "appVersionSource": "local" // or "remote" if you use EAS Update for versions
    }
}